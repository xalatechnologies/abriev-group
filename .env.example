# Optional — OAuth on Vercel (set in Project → Settings → Environment Variables).
# If unset, Google/Facebook sign-in routes stay disabled and the UI shows the unconfigured banner.

# AUTH_PUBLIC_ORIGIN=https://your-domain.vercel.app
# AUTH_GOOGLE_CLIENT_ID=
# AUTH_GOOGLE_CLIENT_SECRET=
# AUTH_FACEBOOK_APP_ID=
# AUTH_FACEBOOK_APP_SECRET=
